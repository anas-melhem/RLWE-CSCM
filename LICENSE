#include "rlwe_cscm/polynomial.hpp"
#include <algorithm>
#include <numeric>

namespace rlwe_cscm {

Polynomial::Polynomial(std::size_t degree, std::int64_t modulus)
    : coeffs_(degree, 0), modulus_(modulus) {
    if (degree == 0 || modulus <= 1) throw std::invalid_argument("invalid polynomial parameters");
}

Polynomial::Polynomial(std::vector<std::int64_t> coeffs, std::int64_t modulus)
    : coeffs_(std::move(coeffs)), modulus_(modulus) {
    if (coeffs_.empty() || modulus <= 1) throw std::invalid_argument("invalid polynomial parameters");
    for (auto& c : coeffs_) c = mod(c, modulus_);
}

Polynomial::Polynomial(std::initializer_list<std::int64_t> coeffs, std::int64_t modulus)
    : Polynomial(std::vector<std::int64_t>(coeffs), modulus) {}

std::int64_t Polynomial::mod(std::int64_t value, std::int64_t q) {
    std::int64_t r = value % q;
    return r < 0 ? r + q : r;
}

std::int64_t Polynomial::mod_mul(std::int64_t a, std::int64_t b, std::int64_t q) {
    __int128 x = static_cast<__int128>(mod(a, q)) * static_cast<__int128>(mod(b, q));
    return static_cast<std::int64_t>(x % q);
}

std::int64_t Polynomial::mod_inv(std::int64_t a, std::int64_t q) {
    a = mod(a, q);
    std::int64_t t = 0, new_t = 1;
    std::int64_t r = q, new_r = a;
    while (new_r != 0) {
        std::int64_t quotient = r / new_r;
        std::int64_t tmp_t = t - quotient * new_t;
        t = new_t;
        new_t = tmp_t;
        std::int64_t tmp_r = r - quotient * new_r;
        r = new_r;
        new_r = tmp_r;
    }
    if (r != 1) throw std::invalid_argument("inverse does not exist");
    return mod(t, q);
}

void Polynomial::ensure_compatible(const Polynomial& other) const {
    if (degree() != other.degree() || modulus_ != other.modulus_) {
        throw std::invalid_argument("incompatible polynomials");
    }
}

Polynomial Polynomial::add(const Polynomial& other) const {
    ensure_compatible(other);
    std::vector<std::int64_t> out(degree());
    for (std::size_t i = 0; i < degree(); ++i) out[i] = mod(coeffs_[i] + other.coeffs_[i], modulus_);
    return Polynomial(out, modulus_);
}

Polynomial Polynomial::sub(const Polynomial& other) const {
    ensure_compatible(other);
    std::vector<std::int64_t> out(degree());
    for (std::size_t i = 0; i < degree(); ++i) out[i] = mod(coeffs_[i] - other.coeffs_[i], modulus_);
    return Polynomial(out, modulus_);
}

Polynomial Polynomial::scalar_mul(std::int64_t k) const {
    std::vector<std::int64_t> out(degree());
    for (std::size_t i = 0; i < degree(); ++i) out[i] = mod_mul(coeffs_[i], k, modulus_);
    return Polynomial(out, modulus_);
}

Polynomial Polynomial::mul(const Polynomial& other) const {
    ensure_compatible(other);
    std::vector<std::int64_t> out(degree(), 0);
    const std::size_t d = degree();
    for (std::size_t i = 0; i < d; ++i) {
        for (std::size_t j = 0; j < d; ++j) {
            std::size_t k = i + j;
            std::int64_t term = mod_mul(coeffs_[i], other.coeffs_[j], modulus_);
            if (k >= d) {
                k -= d;          // x^d = -1 in Z_q[x]/(x^d + 1)
                term = mod(-term, modulus_);
            }
            out[k] = mod(out[k] + term, modulus_);
        }
    }
    return Polynomial(out, modulus_);
}

Polynomial Polynomial::change_modulus(std::int64_t new_modulus) const {
    std::vector<std::int64_t> out(degree());
    for (std::size_t i = 0; i < degree(); ++i) out[i] = mod(coeffs_[i], new_modulus);
    return Polynomial(out, new_modulus);
}

bool Polynomial::equals_mod(const Polynomial& other, std::int64_t m) const {
    if (degree() != other.degree()) return false;
    for (std::size_t i = 0; i < degree(); ++i) {
        if (mod(coeffs_[i] - other.coeffs_[i], m) != 0) return false;
    }
    return true;
}

std::string Polynomial::str() const {
    std::ostringstream os;
    os << "[";
    for (std::size_t i = 0; i < coeffs_.size(); ++i) {
        os << coeffs_[i];
        if (i + 1 < coeffs_.size()) os << ", ";
    }
    os << "] mod " << modulus_;
    return os.str();
}

} // namespace rlwe_cscm
